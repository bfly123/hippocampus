#!/bin/bash
# Hippocampus post-commit hook
# Automatically refresh hippo index after each commit
#
# This hook is synchronous and will block commit completion until indexing finishes.
# Use 'hippo hooks uninstall' to disable if needed.

set -e

# Get the project root (parent of .git)
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# Get commit info
COMMIT_HASH=$(git rev-parse --short HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B | head -1)

echo ""
echo "🦛 Hippocampus: Auto-refreshing index..."
echo ""

# Check if .hippocampus directory exists, if not initialize
if [ ! -d ".hippocampus" ]; then
    echo "📦 Initializing hippocampus..."
    if ! PYTHONWARNINGS="ignore::FutureWarning,ignore::UserWarning" python3 -m hippocampus.cli init --target . 2>&1; then
        echo "⚠️  Initialization failed, skipping index refresh"
        exit 0
    fi
    echo ""
fi

# Quick check: only run index if source files changed
CHANGED_FILES=$(git diff-tree --no-commit-id --name-only -r HEAD)
if ! echo "$CHANGED_FILES" | grep -qE '\.(py|js|ts|go|java|c|cpp|rs)$'; then
    echo "ℹ️  No source files changed, skipping index refresh"
    echo ""
    exit 0
fi

# Run hippo index with proper error handling
echo "📊 Running hippo index..."
echo ""

if PYTHONWARNINGS="ignore::FutureWarning,ignore::UserWarning" python3 -m hippocampus.cli index --target . 2>&1; then
    EXIT_CODE=$?
    if [ $EXIT_CODE -eq 0 ]; then
        echo ""
        echo "✅ Index updated successfully (snapshot auto-created with timestamp)"
    else
        echo ""
        echo "⚠️  Index command exited with code $EXIT_CODE"
    fi
else
    echo ""
    echo "⚠️  Index update failed (non-fatal, commit succeeded)"
fi

echo ""
echo "🎉 Hippocampus auto-refresh complete!"
echo ""

# Always exit successfully to not block the commit
exit 0



