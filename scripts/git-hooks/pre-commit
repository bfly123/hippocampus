#!/bin/bash
# Hippocampus pre-commit hook
# Automatically reviews staged changes against architecture map
#
# This hook blocks the commit if architectural violations are detected.
# Use 'git commit --no-verify' to bypass in emergencies.

# Check if we should skip
if [ "$HIPPO_SKIP_REVIEW" = "1" ]; then
    exit 0
fi

# Get the project root (parent of .git)
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# Check if .hippocampus/structure-prompt.md exists
if [ ! -f ".hippocampus/structure-prompt.md" ]; then
    # Architecture map missing, maybe warn but allow?
    # Or try to generate it?
    # For now, let's just skip review if map is missing to avoid blocking init
    exit 0
fi

echo ""
echo "🦛 Hippocampus: Reviewing architecture..."

# Run hippo review
if PYTHONWARNINGS="ignore::FutureWarning,ignore::UserWarning" python3 -m hippocampus.cli review --staged; then
    exit 0
else
    EXIT_CODE=$?
    echo ""
    echo "❌ Commit blocked by Hippocampus Architecture Review."
    echo "   See issues above."
    echo "   To bypass: git commit --no-verify"
    echo ""
    exit $EXIT_CODE
fi
